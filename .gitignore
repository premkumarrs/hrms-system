# =============================================================================
# HRMS — Git ignore (public repository hygiene)
# =============================================================================

# -----------------------------------------------------------------------------
# Python bytecode and packaging
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg
*.egg-info/
.eggs/
dist/
build/
wheels/
pip-wheel-metadata/
share/python-wheels/

# -----------------------------------------------------------------------------
# Virtual environments (any location)
# -----------------------------------------------------------------------------
venv/
.venv/
env/
ENV/
backend/venv/
frontend/venv/

# -----------------------------------------------------------------------------
# Environment and secrets (keep *.example templates)
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
backend/.env
frontend/.env
*.pem
*.key
*.p12
*.pfx
secrets/
credentials.json

# Explicitly allow committed templates
!.env.example
!**/.env.example
!production.env.example
!**/production.env.example

# -----------------------------------------------------------------------------
# Django runtime data
# -----------------------------------------------------------------------------
backend/staticfiles/
backend/media/
backend/logs/
backend/backups/
*.sqlite3
db.sqlite3

# -----------------------------------------------------------------------------
# Frontend runtime data
# -----------------------------------------------------------------------------
frontend/logs/

# -----------------------------------------------------------------------------
# Database dumps and backups
# -----------------------------------------------------------------------------
*.sql
*.dump
*.backup
*.bak
*.tar.gz
*.zip

# -----------------------------------------------------------------------------
# Logs (any path)
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Test and coverage artifacts
# -----------------------------------------------------------------------------
.coverage
.coverage.*
coverage.xml
htmlcov/
.pytest_cache/
.tox/
.nox/
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.hypothesis/

# -----------------------------------------------------------------------------
# IDE and editor
# -----------------------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/

# -----------------------------------------------------------------------------
# OS files
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Docker (local overrides only; volumes live outside the repo)
# -----------------------------------------------------------------------------
docker-compose.override.yml
.docker/

# -----------------------------------------------------------------------------
# Jupyter / notebooks (optional local artifacts)
# -----------------------------------------------------------------------------
.ipynb_checkpoints/

# -----------------------------------------------------------------------------
# Local tooling
# -----------------------------------------------------------------------------
*.orig
