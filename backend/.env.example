# Local development environment for HRMS backend.
# Copy to backend/.env and adjust values.

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=True

ALLOWED_HOSTS=127.0.0.1,localhost

# PostgreSQL
DB_NAME=hrms_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_HOST=localhost
DB_PORT=5432
# Docker Compose reads DB_* from the repo-root .env for the db service.
# Keep repo-root .env DB_PASSWORD aligned with your PostgreSQL volume.
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True
DB_CONNECT_TIMEOUT=10

# CORS (desktop client uses direct API calls)
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# Static / media
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# Upload limits (bytes)
HRMS_MAX_UPLOAD_BYTES=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO
TIME_ZONE=Asia/Kolkata

# Security (leave false for local HTTP)
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
USE_SECURE_PROXY_SSL_HEADER=False
SECURE_HSTS_SECONDS=0

# JWT (SimpleJWT)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=1
HRMS_LOGIN_THROTTLE=20/minute
HRMS_TOKEN_REFRESH_THROTTLE=60/minute
