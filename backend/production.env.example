# Production environment template for HRMS backend.
# Copy to a secure location (e.g. /etc/hrms/production.env) — never commit real secrets.

SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET
DEBUG=False

ALLOWED_HOSTS=hrms-api.example.com,10.0.0.5

# PostgreSQL
DB_NAME=hrms_db
DB_USER=hrms_app
DB_PASSWORD=REPLACE_WITH_STRONG_DB_PASSWORD
DB_HOST=postgres
DB_PORT=5432
DB_CONN_MAX_AGE=120
DB_CONN_HEALTH_CHECKS=True
DB_CONNECT_TIMEOUT=10

# CORS — list desktop or web client origins only
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://hrms.example.com

# Static / media (use persistent volumes in Docker/production)
STATIC_URL=/static/
STATIC_ROOT=/var/hrms/staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=/var/hrms/media

HRMS_MAX_UPLOAD_BYTES=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

LOG_DIR=/var/log/hrms
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
TIME_ZONE=Asia/Kolkata

# HTTPS / reverse proxy
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=True
USE_SECURE_PROXY_SSL_HEADER=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False
