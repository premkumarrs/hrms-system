# Production environment template for HRMS backend.
# Copy to backend/.env on the server. Set DEBUG=False before go-live.
# Do NOT commit real secrets.

SECRET_KEY=replace-with-long-random-secret-min-50-chars
DEBUG=False

ALLOWED_HOSTS=hrms.example.com,api.example.com
CORS_ALLOW_ALL_ORIGINS=False
CORS_ALLOWED_ORIGINS=https://hrms.example.com

# PostgreSQL (required when DEBUG=False)
DB_NAME=hrms_db
DB_USER=hrms_app
DB_PASSWORD=replace-with-strong-db-password
DB_HOST=db
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONN_HEALTH_CHECKS=True
DB_CONNECT_TIMEOUT=10

# Static / media (use persistent volumes in Docker)
STATIC_URL=/static/
STATIC_ROOT=staticfiles
MEDIA_URL=/media/
MEDIA_ROOT=media

# Upload limits (bytes)
HRMS_MAX_UPLOAD_BYTES=5242880
DATA_UPLOAD_MAX_MEMORY_SIZE=10485760
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Logging
LOG_DIR=logs
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=WARNING
TIME_ZONE=Asia/Kolkata

# TLS / cookies (behind HTTPS reverse proxy)
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False
USE_SECURE_PROXY_SSL_HEADER=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=False

# JWT
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=1
HRMS_LOGIN_THROTTLE=20/minute
HRMS_TOKEN_REFRESH_THROTTLE=60/minute
